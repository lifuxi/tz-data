# ============================================
# tz-data 项目环境配置文件
# ============================================

# === 后端配置 ===

# FastAPI 服务
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Celery 配置
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# === 数据库配置 ===

# SQLite (默认数据库，无需配置)
# 数据库文件位置: C:\myspace\tz-data\data\
#   - tzdata_market.db (市场数据)
#   - tzdata_trading.db (交易数据)
#   - tzdata_analysis.db (分析数据)

# PostgreSQL (可选，如需使用请取消注释并配置)
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=tzdata
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres

# QuestDB (可选，如需使用请取消注释并配置)
# QUESTDB_HOST=localhost
# QUESTDB_PORT=8812
# QUESTDB_DB=questdb

# Redis (可选，用于 Celery 高性能任务队列)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0

# === 前端配置 ===

# Vite Dev Server
VITE_PORT=5000
VITE_API_BASE_URL=http://localhost:8000/api/maintenance

# === 数据目录 ===

TZ_DATA_DIR=C:\myspace\tz-data\data

# === API Keys ===

# Tushare API Token (可选)
TUSHARE_TOKEN=your_tushare_token_here

# CFMMC Cookie 目录
CFMMC_COOKIES_DIR=C:\myspace\tz-data\data\cfmmc\cookies

# === 日志配置 ===

LOG_LEVEL=INFO
LOG_DIR=C:\myspace\tz-data\logs

# === 监控告警配置 ===

# 钉钉机器人 Webhook (可选)
DINGTALK_WEBHOOK_URL=

# 企业微信 Webhook (可选)
WECOM_WEBHOOK_URL=

# SMTP 邮件配置 (可选)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=user@example.com
SMTP_PASSWORD=password
SMTP_FROM_ADDR=alerts@example.com
SMTP_TO_ADDRS=admin@example.com
